&pointing_listener {
    status = "okay";
    device = <&pointing_device>;
    input-processors = <&zip_xy_transform (INPUT_TRANSFORM_X_INVERT | INPUT_TRANSFORM_Y_INVERT)>, <&zip_xy_scaler 2 1>;

    scroll {
        layers = <7>;
        input-processors = <&zip_xy_to_scroll_mapper>, <&zip_scroll_scaler 1 16>;
    };
};
